# ─────────────────────────────────────────────────────────────
# Giftty — environment variables template
# Copy to `.env` and fill in real values. Never commit `.env`.
# ─────────────────────────────────────────────────────────────

# --- App ---
APP_URL=http://localhost:8080
NODE_ENV=development

# --- Auth ---
# Session/signing secret (>= 32 chars). Generate with: openssl rand -hex 32
AUTH_SECRET=

# --- Google OAuth (your own Google Cloud Console credentials) ---
# Create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI to configure in Google Console:
#   https://<your-supabase-project-ref>.supabase.co/auth/v1/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Supabase (backend / DB / Auth) ---
# Public — safe to expose to browser
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# Server-only
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Database (Postgres) ---
DATABASE_URL=

# --- Payments (Razorpay) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- AI Gateway ---
AI_API_KEY=
LOVABLE_API_KEY=

# --- Super admin bootstrap ---
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
